// Swift Tasks — Prisma schema
// Core principle: EVERYTHING is namespaced by projectId (and userId).
// No global singletons; isolation boundary = projectId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Single implicit local user (MVP). Multi-user auth is a later concern;
/// the isolation feature that matters here is per-project, not per-user.
model User {
  id        String   @id @default(cuid())
  email     String   @unique @default("local@swifttasks.dev")
  name      String?  @default("Local Developer")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects  Project[]
  apiKeys   ApiKeyConfig[]
}

/// A self-contained unit: chat history, virtual file system, model config,
/// and live generation state are ALL scoped to this id.
model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  /// Frozen snapshot of the model config used for this project (JSON).
  /// Allows per-project override of account default.
  modelConfig String   @default("{}")
  /// quick status flag for sidebar: idle | generating | error | empty
  status      String   @default("empty")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  files       ProjectFile[]
  messages    ProjectMessage[]
  jobs        GenerationJob[]
  deployments Deployment[]

  @@index([userId])
}

/// Virtual file system entry. version enables history / rollback.
model ProjectFile {
  id        String   @id @default(cuid())
  projectId String
  path      String
  content   String   @default("")
  /// monotonically increasing per (projectId, path)
  version   Int      @default(1)
  /// added | modified | deleted
  lastAction String  @default("added")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, path])
  @@index([projectId])
}

/// Conversation trail for a project. Never shared across projects.
model ProjectMessage {
  id        String   @id @default(cuid())
  projectId String
  role      String   /// user | assistant | system | tool
  content   String   @default("")
  /// optional structured payload (e.g. files written, tokens, error)
  meta      String   @default("{}")
  tokens    Int      @default(0)
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

/// Generation job — makes reconnect/resume possible.
/// The client reattaches to an in-flight job by polling/streaming its events.
model GenerationJob {
  id         String   @id @default(cuid())
  projectId  String
  status     String   @default("queued") /// queued | running | completed | failed | cancelled
  prompt     String   @default("")
  /// running tally for the live status panel
  tokensUsed Int      @default(0)
  filesCompleted Int  @default(0)
  error      String?
  startedAt  DateTime @default(now())
  finishedAt DateTime?

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

/// BYOK storage. The apiKey is AES-256-GCM encrypted at rest and NEVER
/// returned in plaintext to the client (only provider/model/maskedKey).
model ApiKeyConfig {
  id           String   @id @default(cuid())
  userId       String
  label        String   @default("default")
  provider     String   /// openrouter | openai | anthropic | custom | platform
  /// encrypted ciphertext (iv:authTag:ciphertext, base64)
  encryptedKey String   @default("")
  /// user-facing mask, e.g. "sk-...Ab12" — safe to return to client
  maskedKey    String   @default("")
  baseURL      String?
  model        String   @default("")
  isDefault    Boolean  @default(false)
  isValid      Boolean  @default(false)
  lastValidated DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, label])
  @@index([userId])
}

/// Records each deployment of a project to an external host.
/// Tracks the target (netlify | surge | cloudflare | manual), the live URL,
/// and the deploy token label (never the token itself).
model Deployment {
  id          String   @id @default(cuid())
  projectId   String
  target      String   /// netlify | surge | cloudflare | manual
  url         String   /// live URL after deploy
  siteName    String?  /// site/subdomain name
  status      String   @default("deploying") /// deploying | live | failed
  error       String?
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

/// Secure vault for arbitrary API keys / tokens / secrets the user wants to
/// store for easy access (deploy tokens, database URLs, third-party API keys,
/// notes, etc.). The value is AES-256-GCM encrypted at rest and never returned
/// to the client in plaintext — only revealed on explicit "reveal" action.
model VaultEntry {
  id          String   @id @default(cuid())
  userId      String
  label       String
  /// category for icon/color: apikey | token | note | password | other
  category    String   @default("apikey")
  /// encrypted ciphertext (iv:authTag:ciphertext, base64)
  encryptedValue String @default("")
  /// user-facing mask, e.g. "sk-...Ab12"
  maskedValue String   @default("")
  /// optional note shown in plaintext
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

